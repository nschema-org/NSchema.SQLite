<Project>

  <ItemGroup>
    <!--
      Microsoft.Data.Sqlite bundles the native SQLite engine via SQLitePCLRaw.lib.e_sqlite3, whose latest
      published build (2.1.11) carries advisory GHSA-2m69-gcr7-jv3q. There is no fixed release to upgrade to
      yet, so this single advisory is suppressed to keep `NuGetAudit` + `TreatWarningsAsErrors` from failing the
      build. Remove this once a patched e_sqlite3 ships.
    -->
    <NuGetAuditSuppress Include="https://github.com/advisories/GHSA-2m69-gcr7-jv3q" />
  </ItemGroup>

</Project>
